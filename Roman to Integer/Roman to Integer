class Solution:
    def romanToInt(self, s: str) -> int:
        roman = {
            "I": 1,
            "V": 5,
            "X": 10,
            "L": 50,
            "C": 100,
            "D": 500,
            "M": 1000}
        total = 0 
        for l in range(len(s) - 1):
            if roman[s[l]] < roman[s[l+1]]:
                total += -(roman[s[l]]) 
            else:
                total +=roman[s[l]] 
        total += roman[s[-1]]
        return total


            